<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="➕ Recruit a Pet"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pet Name"
            android:textColor="#CCCCCC"
            android:layout_marginBottom="4dp"/>

        <EditText android:id="@+id/etPetName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter a name..."
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            android:textColorHint="#888888"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Specialization"
            android:textColor="#CCCCCC"
            android:layout_marginBottom="4dp"/>

        <Spinner android:id="@+id/spSpecialization"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <TextView android:id="@+id/tvSpecStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="#16213E"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="24dp"
            android:text=""/>

        <Button android:id="@+id/btnCreatePet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🐾 Recruit!"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btnCancelRecruitment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:backgroundTint="#607D8B"
                android:textColor="#FFFFFF"/>
    </LinearLayout>
</ScrollView>