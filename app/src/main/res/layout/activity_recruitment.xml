<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pink_background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="32dp">

        <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="➕ Recruit a New Friend"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="@font/cute_font"
        android:textColor="@color/text_color_primary"
        android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pet Name ✨"
            android:fontFamily="@font/cute_font"
            android:textColor="@color/text_color_secondary"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <EditText android:id="@+id/etPetName"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:hint="Enter name..."
                android:background="@drawable/edit_text_rounded_bg"
                android:paddingHorizontal="16dp"
                android:fontFamily="@font/cute_font"
                android:inputType="textPersonName"/>

            <Button android:id="@+id/btnRandomName"
                android:layout_width="60dp"
                android:layout_height="50dp"
                android:text="🎲"
                android:layout_marginStart="8dp"
                android:backgroundTint="#B39DDB"
                app:cornerRadius="12dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Specialization 🎀"
            android:fontFamily="@font/cute_font"
            android:textColor="@color/text_color_secondary"
            android:layout_marginBottom="8dp"/>

        <Spinner android:id="@+id/spSpecialization"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="20dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="15dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="32dp">

            <TextView android:id="@+id/tvSpecStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:background="@color/pink_primary_light"
                android:textColor="@color/text_color_primary"
                android:textSize="14sp"
                android:fontFamily="@font/cute_font"
                android:text="Select a specialization to see stats."/>
        </androidx.cardview.widget.CardView>

        <Button android:id="@+id/btnCreatePet"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="🐾 Welcome to the Academy!"
            android:backgroundTint="@color/pink_primary"
            android:textColor="@color/white"
            android:fontFamily="@font/cute_font"
            android:layout_marginBottom="12dp"
            app:cornerRadius="15dp"/>

        <Button android:id="@+id/btnCancelRecruitment"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Maybe Later"
            android:backgroundTint="#B39DDB"
            android:fontFamily="@font/cute_font"
            app:cornerRadius="12dp"/>
    </LinearLayout>
</ScrollView>