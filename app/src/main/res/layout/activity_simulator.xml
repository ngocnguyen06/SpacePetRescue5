<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pink_background"
    android:padding="4dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✨ Training Simulator"
        android:fontFamily="@font/cute_font"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_color_primary"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/cute_font"
        android:text="Train your pets to gain extra skill power 🎀"
        android:textColor="@color/text_color_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"/>

    <TextView android:id="@+id/tvSimulatorEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="The simulator is quiet... ✨\nMove pets here from Quarters to start training!"
        android:textColor="@color/text_color_secondary"
        android:gravity="center"
        android:fontFamily="@font/cute_font"
        android:padding="24dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSimulator"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"/>

    <Button android:id="@+id/btnTrain"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="🌟 Start Training (+1 XP)"
        android:backgroundTint="@color/pink_primary"
        android:fontFamily="@font/cute_font"
        android:textColor="@color/white"
        android:layout_marginBottom="8dp"
        app:cornerRadius="15dp"/>

    <Button android:id="@+id/btnSimToQuarters"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="🏠 Finish &amp; Back to Quarters"
        android:backgroundTint="#B39DDB"
        android:fontFamily="@font/cute_font"
        android:textColor="@color/white"
        android:layout_marginBottom="8dp"
        app:cornerRadius="15dp"/>

    <Button android:id="@+id/btnSimulatorBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Back to Academy"
        android:backgroundTint="@color/pink_primary_dark"
        android:fontFamily="@font/cute_font"
        android:textColor="@color/white"
        app:cornerRadius="12dp"/>

</LinearLayout>