<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏋️ Training Simulator"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FF9800"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Train pets to increase their Skill Power."
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"/>

    <TextView android:id="@+id/tvSimulatorEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="The simulator is currently empty. Move pets here from Quarters to begin training."
        android:textColor="#888888"
        android:gravity="center"
        android:padding="20dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSimulator"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"
        android:scrollbars="vertical"/>

    <Button android:id="@+id/btnTrain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🌟 Train Selected (+1 XP)"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <Button android:id="@+id/btnSimToQuarters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🏠 Finish &amp; Return to Quarters"
        android:backgroundTint="#2196F3"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <Button android:id="@+id/btnSimulatorBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Back to Overview"
        android:backgroundTint="#607D8B"
        android:textColor="#FFFFFF"/>

</LinearLayout>