<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:background="@drawable/edit_text_rounded_bg"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center">

    <TextView
        android:id="@+id/tvGuideTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/guide_title"
        android:fontFamily="@font/cute_font"
        android:textSize="22sp"
        android:textColor="@color/pink_primary"
        android:layout_marginBottom="15dp"/>

    <TextView
        android:id="@+id/tvGuideContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/guide_content"
        android:fontFamily="@font/cute_font"
        android:textSize="16sp"
        android:textColor="#444444"
        android:lineSpacingExtra="5dp"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnCloseGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OK 🐾"
        style="@style/CuteButtonStyle"
        android:paddingHorizontal="30dp"/>
</LinearLayout>