<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F1B">

    <!-- Selection Phase -->
    <LinearLayout
        android:id="@+id/layoutMissionSelection"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚀 Mission Preparation"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#F44336"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvSelectionHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select exactly 2 pets for the mission"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="16dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMissionPets"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnLaunchMission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LAUNCH MISSION"
            android:backgroundTint="#F44336"
            android:enabled="false"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnMissionBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:backgroundTint="#607D8B"/>
    </LinearLayout>

    <!-- Battle Phase -->
    <LinearLayout
        android:id="@+id/layoutBattleArena"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <!-- Threat Info -->
        <TextView
            android:id="@+id/tvThreatName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THREAT"
            android:textSize="20sp"
            android:textColor="#FF5252"
            android:layout_gravity="center_horizontal" />

        <ProgressBar
            android:id="@+id/pbThreat"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="#FF5252" />

        <TextView
            android:id="@+id/tvThreatHp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/0"
            android:textColor="#FF5252"
            android:layout_gravity="end" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#333333"
            android:layout_marginVertical="16dp" />

        <!-- Pets Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Pet A -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="4dp">
                <TextView
                    android:id="@+id/tvPetAName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pet A"
                    android:textColor="#FFFFFF"
                    android:ellipsize="end"
                    android:maxLines="1" />
                <ProgressBar
                    android:id="@+id/pbPetA"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="#4CAF50" />
                <TextView
                    android:id="@+id/tvPetAHp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/0"
                    android:textSize="10sp"
                    android:textColor="#AAAAAA" />
            </LinearLayout>

            <!-- Pet B -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="4dp">
                <TextView
                    android:id="@+id/tvPetBName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pet B"
                    android:textColor="#FFFFFF"
                    android:ellipsize="end"
                    android:maxLines="1" />
                <ProgressBar
                    android:id="@+id/pbPetB"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="#4CAF50" />
                <TextView
                    android:id="@+id/tvPetBHp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/0"
                    android:textSize="10sp"
                    android:textColor="#AAAAAA" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvActivePet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your turn"
            android:layout_gravity="center_horizontal"
            android:layout_marginVertical="8dp"
            android:textColor="#FFFFFF" />

        <!-- Log -->
        <ScrollView
            android:id="@+id/svBattleLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#1A1A2E"
            android:padding="8dp">
            <TextView
                android:id="@+id/tvBattleLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="12sp" />
        </ScrollView>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">
            <Button
                android:id="@+id/btnAttack"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ATTACK"
                android:layout_marginEnd="4dp" />
            <Button
                android:id="@+id/btnSpecial"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SPECIAL"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnEndMission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Finish Mission"
            android:visibility="gone"
            android:layout_marginTop="8dp" />
    </LinearLayout>
</FrameLayout>