<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#2C3E50">

    <LinearLayout
        android:id="@+id/layoutMissionSelection"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginTop="32dp"
        android:visibility="visible">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mission Control"
            android:textColor="#ECF0F1"
            android:textSize="24sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvSelectionHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select 2 Pets for the mission"
            android:textColor="#BDC3C7"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="10dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMissionPets"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="10dp" />

        <Spinner
            android:id="@+id/spnMissionLevels"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="48dp"
            android:background="#34495E" />

        <Button
            android:id="@+id/btnLaunchMission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LAUNCH MISSION"
            android:enabled="false" />

        <Button
            android:id="@+id/btnMissionBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BACK"
            android:backgroundTint="#E74C3C" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/layoutBattleArena"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvThreatName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Threat"
                android:textColor="#E74C3C"
                android:textSize="20sp"
                android:layout_gravity="center_horizontal" />

            <ProgressBar
                android:id="@+id/pbThreat"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvThreatHp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100/100"
                android:textColor="#ECF0F1"
                android:layout_gravity="center_horizontal" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#7F8C8D"
                android:layout_marginVertical="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvPetAName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pet A"
                        android:textColor="#3498DB" />
                    <ProgressBar
                        android:id="@+id/pbPetA"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                    <TextView
                        android:id="@+id/tvPetAHp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100/100"
                        android:textColor="#ECF0F1" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvPetBName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pet B"
                        android:textColor="#F1C40F" />
                    <ProgressBar
                        android:id="@+id/pbPetB"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                    <TextView
                        android:id="@+id/tvPetBHp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100/100"
                        android:textColor="#ECF0F1" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvActivePet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginVertical="20dp"
                android:text="Ready!"
                android:textColor="#ECF0F1"
                android:textSize="18sp" />

            <ScrollView
                android:id="@+id/svBattleLog"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="#1C2833"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tvBattleLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#95A5A6"
                    android:text="Battle Log..." />
            </ScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">
                <Button
                    android:id="@+id/btnAttack"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Attack" />
                <Button
                    android:id="@+id/btnSpecial"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Special" />
            </LinearLayout>

            <Button
                android:id="@+id/btnEndMission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FINISH MISSION"
                android:visibility="gone"
                android:layout_marginTop="10dp" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>