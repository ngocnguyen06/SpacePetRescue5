<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pink_background">

    <LinearLayout
        android:id="@+id/layoutMissionSelection"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚀 Mission Preparation"
            android:textSize="24sp"
            android:fontFamily="@font/cute_font"
            android:textColor="@color/text_color_primary"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvSelectionHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/cute_font"
            android:text="Select exactly 2 pets for the mission ✨"
            android:textColor="@color/text_color_secondary"
            android:layout_marginBottom="16dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMissionPets"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Mission Level:"
            android:fontFamily="@font/cute_font"
            android:textColor="@color/text_color_primary"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spnMissionLevels"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:padding="8dp"
            android:background="@android:drawable/btn_dropdown"/>

        <Button
            android:id="@+id/btnLaunchMission"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="LAUNCH MISSION 🎀"
            android:backgroundTint="@color/pink_accent"
            android:textColor="@color/white"
            android:enabled="false"
            android:layout_marginBottom="8dp"
            app:cornerRadius="15dp"/>

        <Button
            android:id="@+id/btnMissionBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:backgroundTint="#B39DDB"
            app:cornerRadius="12dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutBattleArena"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="15dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@color/card_background">

                <TextView
                    android:id="@+id/tvThreatName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👾 THREAT"
                    android:textSize="18sp"
                    android:fontFamily="@font/cute_font"
                    android:textStyle="bold"
                    android:textColor="#D32F2F"
                    android:layout_gravity="center_horizontal" />

                <ProgressBar
                    android:id="@+id/pbThreat"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:progressTint="#D32F2F"
                    android:layout_marginVertical="4dp" />

                <TextView
                    android:id="@+id/tvThreatHp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/0"
                    android:fontFamily="@font/cute_font"
                    android:textStyle="bold"
                    android:textColor="#D32F2F"
                    android:layout_gravity="end" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/pink_primary_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/tvPetAName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pet A"
                        android:fontFamily="@font/cute_font"
                        android:textColor="@color/text_color_primary"
                        android:textStyle="bold"
                        android:ellipsize="end"
                        android:maxLines="1" />
                    <ProgressBar
                        android:id="@+id/pbPetA"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:progressTint="#388E3C" />
                    <TextView
                        android:id="@+id/tvPetAHp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/0"
                        android:fontFamily="@font/cute_font"
                        android:textSize="11sp"
                        android:textColor="@color/text_color_secondary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/pink_primary_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <TextView
                        android:id="@+id/tvPetBName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pet B"
                        android:textColor="@color/text_color_primary"
                        android:textStyle="bold"
                        android:ellipsize="end"
                        android:fontFamily="@font/cute_font"
                        android:maxLines="1" />
                    <ProgressBar
                        android:id="@+id/pbPetB"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:progressTint="#388E3C" />
                    <TextView
                        android:id="@+id/tvPetBHp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cute_font"
                        android:text="0/0"
                        android:textSize="11sp"
                        android:textColor="@color/text_color_secondary" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <TextView
            android:id="@+id/tvActivePet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your turn ✨"
            android:textStyle="bold"
            android:fontFamily="@font/cute_font"
            android:layout_gravity="center_horizontal"
            android:layout_marginVertical="12dp"
            android:textColor="@color/text_color_primary" />

        <ScrollView
            android:id="@+id/svBattleLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/card_background"
            android:padding="8dp"
            android:fadeScrollbars="false">
            <TextView
                android:id="@+id/tvBattleLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_color_secondary"
                android:fontFamily="@font/cute_font"
                android:textSize="13sp" />
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">
            <Button
                android:id="@+id/btnAttack"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:text="ATTACK 💢"
                android:backgroundTint="@color/pink_accent"
                android:layout_marginEnd="6dp"
                app:cornerRadius="15dp"/>
            <Button
                android:id="@+id/btnSpecial"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:text="SPECIAL ✨"
                android:backgroundTint="#FFB74D"
                android:layout_marginStart="6dp"
                app:cornerRadius="15dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnEndMission"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Finish Mission 🏠"
            android:backgroundTint="@color/pink_primary"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            app:cornerRadius="15dp"/>
    </LinearLayout>
</FrameLayout>