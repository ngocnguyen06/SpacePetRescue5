<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.MissionControlActivity"
    android:background="@color/colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:id="@+id/ivMissionLogo"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/ic_launcher_foreground"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:contentDescription="Mission Control Logo" />

            <TextView
                android:id="@+id/tvMissionControlTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MISSION CONTROL"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/colorAccent"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="System Status: Operational"
                android:textSize="14sp"
                android:textColor="@color/text_color_secondary"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="32dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="#34495E"
                    app:cardCornerRadius="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvFuelLevel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="85%"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#2ECC71" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FUEL"
                            android:textSize="12sp"
                            android:textColor="#BDC3C7" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="#34495E"
                    app:cardCornerRadius="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvOxygenLevel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="92%"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#3498DB" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OXYGEN"
                            android:textSize="12sp"
                            android:textColor="#BDC3C7" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <Button
                android:id="@+id/btnLaunchRescue"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="LAUNCH RESCUE MISSION"
                android:backgroundTint="@color/colorAccent"
                android:textColor="@color/text_color_primary"
                android:layout_gravity="center_horizontal" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#7F8C8D"
                android:layout_marginVertical="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#2C3E50"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvPetAName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pet A"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#3498DB" />

                    <TextView
                        android:id="@+id/tvPetAStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status: Waiting for Rescue"
                        android:textSize="14sp"
                        android:textColor="#BDC3C7" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#2C3E50"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvPetBName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pet B"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#E67E22" />

                    <TextView
                        android:id="@+id/tvPetBStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status: Signal Lost"
                        android:textSize="14sp"
                        android:textColor="#BDC3C7" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>