<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFE4E1"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚀 Space Pet Rescue Academy"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Colony Overview"
            android:textSize="14sp"
            android:textColor="#000000"
            android:layout_marginBottom="16dp"/>

        <!-- Status card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFB6C1"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView android:id="@+id/tvQuartersCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="16sp"
                android:layout_marginBottom="4dp"
                android:text="🏠 Quarters: 0"/>

            <TextView android:id="@+id/tvSimulatorCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="16sp"
                android:layout_marginBottom="4dp"
                android:text="🏋️ Simulator: 0"/>

            <TextView android:id="@+id/tvMissionControlCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="16sp"
                android:layout_marginBottom="4dp"
                android:text="🚀 Mission Control: 0"/>

            <TextView android:id="@+id/tvMedbayCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="16sp"
                android:layout_marginBottom="4dp"
                android:text="🏥 Medbay: 0"/>

            <TextView android:id="@+id/tvMissionsTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="14sp"
                android:text="Missions completed: 0"/>
        </LinearLayout>

        <!-- Navigation buttons -->
        <Button android:id="@+id/btnGoRecruitment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="➕ Recruit New Pet"
            android:backgroundTint="#4CAF50"
            android:textColor="#000000"
            android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btnGoQuarters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏠 Quarters"
            android:backgroundTint="#2196F3"
            android:textColor="#000000"
            android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btnGoSimulator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏋️ Simulator"
            android:backgroundTint="#FF9800"
            android:textColor="#000000"
            android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btnGoMission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚀 Mission Control"
            android:backgroundTint="#F44336"
            android:textColor="#000000"
            android:layout_marginBottom="16dp"/>

        <!-- Save/Load row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💾 Save"
                android:backgroundTint="#607D8B"
                android:textColor="#000000"
                android:layout_marginEnd="4dp"/>

            <Button android:id="@+id/btnLoad"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📂 Load"
                android:backgroundTint="#607D8B"
                android:textColor="#000000"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>