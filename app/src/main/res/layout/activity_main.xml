<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pink_background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="40dp">

        <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/main_title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="@font/cute_font"
        android:textColor="@color/text_color_primary"
        android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/main_subtitle"
            android:fontFamily="@font/cute_font"
            android:textSize="16sp"
            android:textColor="@color/text_color_secondary"
            android:layout_marginBottom="24dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/pink_primary_light"
                android:padding="20dp">

                <TextView android:id="@+id/tvQuartersCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_color_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/cute_font"
                    android:layout_marginBottom="8dp" />

                <TextView android:id="@+id/tvSimulatorCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_color_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/cute_font"
                    android:layout_marginBottom="8dp" />

                <TextView android:id="@+id/tvMissionControlCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_color_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/cute_font"
                    android:layout_marginBottom="8dp" />

                <TextView android:id="@+id/tvMedbayCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_color_primary"
                    android:textSize="16sp"
                    android:fontFamily="@font/cute_font"
                    android:layout_marginBottom="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/pink_primary"
                    android:layout_marginBottom="12dp"/>

                <TextView android:id="@+id/tvMissionsTotal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_color_secondary"
                    android:textSize="14sp"
                    android:fontFamily="@font/cute_font"
                    android:textStyle="italic" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button android:id="@+id/btnGoRecruitment"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/btn_recruit_new"
            android:backgroundTint="@color/pink_primary"
            android:textColor="@color/white"
            android:layout_marginBottom="12dp"
            app:cornerRadius="15dp"/>

        <Button android:id="@+id/btnGoQuarters"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/btn_quarters"
            android:backgroundTint="@color/pink_primary"
            android:textColor="@color/white"
            android:layout_marginBottom="12dp"
            app:cornerRadius="15dp"/>

        <Button android:id="@+id/btnGoSimulator"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/btn_training_room"
            android:backgroundTint="@color/pink_primary"
            android:textColor="@color/white"
            android:layout_marginBottom="12dp"
            app:cornerRadius="15dp"/>

        <Button android:id="@+id/btnGoMission"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/btn_mission_launch"
            android:backgroundTint="@color/pink_accent"
            android:textColor="@color/white"
            android:layout_marginBottom="24dp"
            app:cornerRadius="15dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_save"
                android:backgroundTint="#B39DDB"
                android:textColor="@color/white"
                android:layout_marginEnd="6dp"
                app:cornerRadius="12dp"/>

            <Button android:id="@+id/btnLoad"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_load"
                android:backgroundTint="#B39DDB"
                android:textColor="@color/white"
                android:layout_marginStart="6dp"
                app:cornerRadius="12dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>