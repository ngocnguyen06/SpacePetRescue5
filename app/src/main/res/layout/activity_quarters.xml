<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏠 Quarters"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#2196F3"
        android:layout_marginBottom="16dp"/>

    <TextView android:id="@+id/tvQuartersEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No pets currently in Quarters."
        android:textColor="#AAAAAA"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvQuarters"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"/>

    <Button android:id="@+id/btnMoveToSimulator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🏋️ Move to Simulator"
        android:backgroundTint="#FF9800"
        android:layout_marginBottom="8dp"/>

    <Button android:id="@+id/btnMoveToMission"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🚀 Move to Mission Control"
        android:backgroundTint="#F44336"
        android:layout_marginBottom="8dp"/>

    <Button android:id="@+id/btnQuartersBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Back"
        android:backgroundTint="#607D8B"/>
</LinearLayout>