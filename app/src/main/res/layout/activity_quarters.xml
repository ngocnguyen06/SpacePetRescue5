<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pink_background"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏠 Pet Quarters"
        android:textSize="28sp"
        android:fontFamily="@font/cute_font"
        android:textStyle="bold"
        android:textColor="@color/text_color_primary"
        android:layout_marginTop="48dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rest and relaxation area 🎀"
        android:fontFamily="@font/cute_font"
        android:textColor="@color/text_color_secondary"
        android:layout_marginBottom="16dp"/>

    <TextView android:id="@+id/tvQuartersEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="All pets are busy exploring! 🛸\nNo pets currently in Quarters."
        android:gravity="center"
        android:textColor="@color/text_color_primary"
        android:textSize="16sp"
        android:padding="20dp"
        android:fontFamily="@font/cute_font"
        android:visibility="gone"/>

    <Button
        android:id="@+id/btnSelectAll"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✅ Select All"
        android:layout_gravity="end"
        android:textSize="12sp"
        android:backgroundTint="#81C784"
        android:layout_marginBottom="8dp"
        app:cornerRadius="8dp"
        android:fontFamily="@font/cute_font"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvQuarters"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp" />

    <Button android:id="@+id/btnMoveToSimulator"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="✨ Move to Training Room"
        android:backgroundTint="@color/pink_primary"
        android:layout_marginBottom="8dp"
        app:cornerRadius="15dp"/>

    <Button android:id="@+id/btnMoveToMission"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="🚀 Move to Mission Control"
        android:backgroundTint="@color/pink_accent"
        android:layout_marginBottom="12dp"
        app:cornerRadius="15dp"/>

    <Button android:id="@+id/btnQuartersBack"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Back to Academy"
        android:backgroundTint="#B39DDB"
        app:cornerRadius="12dp"/>


</LinearLayout>