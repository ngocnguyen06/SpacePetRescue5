<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/card_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/pink_primary_light">

            <ImageView
                android:id="@+id/ivCrewAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp"
                android:src="@drawable/pet_pilot_cute"
                android:scaleType="centerInside"
                android:adjustViewBounds="true"/>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/tvCrewName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Snowball"
                android:fontFamily="@font/cute_font"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_color_primary"/>

            <TextView
                android:id="@+id/tvCrewSpec"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/cute_font"
                android:text="Pilot 🚀"
                android:textColor="@color/text_color_secondary"
                android:textStyle="italic"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvCrewStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skill: 5 | Res: 4"
                android:textColor="@color/text_color_primary"
                android:textSize="12sp"
                android:fontFamily="@font/cute_font"
                android:layout_marginTop="2dp"
                android:textStyle="bold"/>

            <ProgressBar
                android:id="@+id/pbCrewEnergy"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="6dp"
                android:progress="100"
                android:progressTint="@color/pink_accent"
                android:progressBackgroundTint="@color/pink_primary_light"/>

            <TextView
                android:id="@+id/tvEnergyLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100/100"
                android:textSize="10sp"
                android:fontFamily="@font/cute_font"
                android:layout_gravity="end"
                android:textStyle="bold"
                android:textColor="@color/text_color_secondary"/>

        </LinearLayout>

        <CheckBox
            android:id="@+id/cbCrewSelect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:buttonTint="@color/pink_accent"
            android:visibility="gone"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>